[node name="NpcMonk" parent="NPC" instance=ExtResource("npc_scene")]
position = Vector2(0, -150)
npc_id = &"npc_monk"
npc_name = "修道士"
dialogues = Array[String](["神の祝福がありますように。", "傷を負ったら無理せず戻ってきなさい。", "この村は平和だが、外は危険に満ちている。"])
sprite_frames = ExtResource("12_23nuo")

[node name="NpcLancer" parent="NPC" instance=ExtResource("npc_scene")]
position = Vector2(292, -20)
npc_id = &"npc_lancer"
npc_name = "槍兵"
dialogues = Array[String](["草原の魔物は手強いぞ。油断するなよ。", "槍は間合いが命だ。近すぎても遠すぎてもダメだ。", "村を守るのが俺の仕事だ。お前は外の脅威を頼む。"])
gift_items = Array[StringName]([&"iron_sword", &"leather_armor", &"swift_ring"])
gift_dialogue = "これを使え。鉄の剣、革の鎧、疾風の指輪だ。メニューのインベントリタブから装備するんだぞ。"

