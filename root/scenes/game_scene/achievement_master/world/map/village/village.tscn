[node name="NpcArcher" parent="NPC" instance=ExtResource("npc_scene")]
position = Vector2(-385, 190)
npc_id = &"npc_archer"
npc_name = "弓使い"
dialogues = Array[String](["この先の草原には魔物がいるから気をつけろ。", "弓の腕には自信がある。だが、近づかれると厄介だ。", "冒険者か？ まずは村で準備を整えるといい。"])
